# =============================================================================
# WildFirePrediction — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# S3 / MinIO Configuration
# -----------------------------------------------------------------------------
S3_ENDPOINT_URL=https://minio.lab.sspcloud.fr
S3_BUCKET=<your-username>/wildfire-prediction
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""

# -----------------------------------------------------------------------------
# MLflow Configuration
# On SSP Cloud, use the shared MLflow instance:
#   https://user-<username>.user.lab.sspcloud.fr/mlflow
# Locally, leave empty or set to ./mlruns for file-based tracking.
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=https://user-<your-username>.user.lab.sspcloud.fr/
MLFLOW_EXPERIMENT_NAME="wildfire_xgboost"
MLFLOW_TRACKING_USERNAME=""
MLFLOW_TRACKING_PASSWORD=""

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_PORT=8000